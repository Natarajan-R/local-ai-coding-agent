dominoes = [(1, 2), (2, 1), (3, 4), (4, 3)]

    def can_chain(dominoes):
        """
        Determine if a chain of dominoes can be formed such that the end number of one domino matches the start number of the next.
    
        Args:
        dominoes (List[List[int]]): A list of dominoes represented as [a, b].
    
        Returns:
        bool: True if a chain can be formed, False otherwise.
        """
        if not dominoes:
            return True
    
        # Create a graph where each node is a unique number from the dominoes
        graph = {}
        for domino in dominoes:
            for number in domino:
                if number not in graph:
                    graph[number] = []
    
        # Build the graph
        for domino in dominoes:
            graph[domino[0]].append(domino[1])
    
        # Find the start and end numbers
        start_numbers = set(graph.keys()) - set([domino[1] for domino in dominoes])
        end_numbers = set(graph.keys()) - set([domino[0] for domino in dominoes])
    
        # If there are more than 2 unique start or end numbers, it's impossible to form a chain
        if len(start_numbers) > 1 or len(end_numbers) > 1:
            return False
    
        # Perform a depth-first search to check if a valid chain can be formed
        visited = set()
    
        def dfs(current):
            if current in visited:
                return False
            visited.add(current)
            for neighbor in graph[current]:
                if not dfs(neighbor):
                    return False
            return True
    
        # Start the DFS from the start number
>       return dfs(next(iter(start_numbers)))
                   ^^^^^^^^^^^^^^^^^^^^^^^^^
