input_string = '(;A[hello\t\tworld])'

    def parse(input_string):
        if not input_string or not input_string.startswith('(') or not input_string.endswith(')'):
            raise ValueError("Invalid SGF format")
    
        def parse_node(node_str):
            properties = {}
            while node_str:
                match = re.match(r';([A-Z]+)\[([^\]]*)\]', node_str)
                if not match:
                    raise ValueError("Invalid property format")
                key, value = match.groups()
                if not key.isupper():
                    raise ValueError("property must be in uppercase")
                if key in properties:
                    properties[key].append(value)
                else:
                    properties[key] = [value]
                node_str = node_str[match.end():]
            return properties
    
        def parse_tree(tree_str):
            nodes = []
            i = 0
            while i < len(tree_str):
                if tree_str[i] == '(':
                    j = i + 1
                    balance = 1
                    while j < len(tree_str) and balance > 0:
                        if tree_str[j] == '(':
                            balance += 1
                        elif tree_str[j] == ')':
                            balance -= 1
                        j += 1
                    node_str = tree_str[i + 1:j - 1]
                    properties = parse_node(node_str)
                    children = parse_tree(tree_str[i + 1:j - 1])
                    nodes.append(SgfTree(properties, children))
                    i = j
                else:
                    i += 1
            return nodes
    
