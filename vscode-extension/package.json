{
  "name": "ai-coding-agent",
  "displayName": "AI Coding Agent",
  "description": "Drive the local AI Coding Agent from VS Code: live run dashboard with native command-approval and hint prompts.",
  "version": "0.1.0",
  "publisher": "ai-coding-agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Natarajan-R/local-ai-coding-agent.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiAgent.openDashboard",
        "title": "AI Agent: Open Dashboard"
      },
      {
        "command": "aiAgent.runTask",
        "title": "AI Agent: Run Task\u2026"
      }
    ],
    "configuration": {
      "title": "AI Coding Agent",
      "properties": {
        "aiAgent.serverUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:8765",
          "description": "URL of a running `ai-agent serve` instance."
        },
        "aiAgent.token": {
          "type": "string",
          "default": "",
          "description": "Session token printed by `ai-agent serve` (the ?token=\u2026 value). Required unless the server runs with --no-auth."
        },
        "aiAgent.autoApprove": {
          "type": "boolean",
          "default": false,
          "description": "Run in --auto mode (skip command-approval prompts)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && npm run check-webview && npx --yes @vscode/vsce package --allow-missing-repository",
    "check-webview": "node scripts/check-webview.js out/extension.js"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.0"
  }
}
